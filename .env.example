# Database (Neon Postgres) — pooled connection string from Neon dashboard
DATABASE_URL=

# Symmetric key for AES-GCM encryption of per-user Anthropic API keys.
# Generate with: openssl rand -base64 32
# This is treated as immutable for v1 (rotating it requires users to re-enter their API key).
API_KEY_ENCRYPTION_KEY=

# Resend (transactional email for magic links)
RESEND_API_KEY=
# The address magic-link emails are sent FROM. Must be a verified Resend sender.
# Until a custom domain is verified, use Resend's onboarding domain.
EMAIL_FROM=Priorities <onboarding@resend.dev>

# Public site URL — used to build magic-link callback URLs.
# Local dev: http://localhost:3000
# Vercel: https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Cron secret — protects /api/cron/* routes from unauthorized invocation.
# Set this in Vercel; cron jobs are configured to send "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

# Optional: Vercel Blob storage for PriorityFile attachments (M6).
# Leave blank in v1 if not using Blob; uploads are deferred until this is set.
BLOB_READ_WRITE_TOKEN=
